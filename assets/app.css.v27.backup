:root{color-scheme:dark;--bg:#0b1220;--panel:rgba(15,23,42,.78);--card:rgba(255,255,255,.06);--line:rgba(255,255,255,.12);--text:#f8fafc;--muted:#94a3b8;--green:#4ade80;--blue:#60a5fa;--purple:#c084fc;--red:#f87171;--yellow:#facc15}*{box-sizing:border-box}body{margin:0;min-height:100vh;background:radial-gradient(circle at top left,rgba(74,222,128,.18),transparent 28%),radial-gradient(circle at bottom right,rgba(96,165,250,.2),transparent 30%),linear-gradient(135deg,#0f2027,#203a43,#2c5364);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Noto Sans SC",Arial,sans-serif}.app-shell{display:grid;grid-template-columns:280px 1fr;min-height:100vh}.sidebar{padding:22px;border-right:1px solid var(--line);background:rgba(2,6,23,.55);backdrop-filter:blur(18px);display:flex;flex-direction:column}.brand{display:flex;gap:12px;align-items:center;margin-bottom:26px}.logo{width:44px;height:44px;border-radius:14px;background:linear-gradient(135deg,var(--green),var(--blue));display:grid;place-items:center;font-weight:900;color:#061018}.brand h1{font-size:18px;margin:0}.brand p{margin:4px 0 0;color:var(--muted);font-size:12px}.side-nav{display:grid;gap:10px}.nav-item,.btn{border:1px solid var(--line);background:rgba(255,255,255,.07);color:var(--text);border-radius:12px;padding:11px 14px;cursor:pointer;transition:.18s;font-weight:700}.nav-item{text-align:left}.nav-item:hover,.btn:hover{transform:translateY(-1px);background:rgba(255,255,255,.13)}.nav-item.active{background:rgba(74,222,128,.16);border-color:rgba(74,222,128,.5);color:#bbf7d0}.sidebar-foot{margin-top:auto;color:var(--muted);font-size:12px;display:grid;gap:8px}.sidebar-foot a{color:#7dd3fc;text-decoration:none}.main{padding:24px;overflow:auto}.topbar{display:flex;justify-content:space-between;gap:18px;align-items:center;margin-bottom:18px;padding:18px 20px;border:1px solid var(--line);border-radius:18px;background:var(--panel);backdrop-filter:blur(18px)}.topbar h2{margin:0;font-size:24px}.topbar p{margin:5px 0 0;color:var(--muted)}.top-stats{display:flex;gap:10px;flex-wrap:wrap}.top-stats span{padding:9px 12px;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.05);color:var(--muted)}.top-stats b{color:var(--text)}.page{display:none}.page.active{display:block}.card,.stat-card{border:1px solid var(--line);border-radius:18px;background:var(--card);backdrop-filter:blur(18px);box-shadow:0 16px 50px rgba(0,0,0,.18)}.card{padding:18px;margin-bottom:16px}.section-title{display:flex;justify-content:space-between;gap:12px;align-items:center;margin-bottom:14px}.section-title h3{margin:0}.section-title span,.hint{color:var(--muted);font-size:13px}.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:16px}.stat-card{padding:18px;color:var(--muted)}.stat-card b{display:block;font-size:30px;color:var(--text);margin-top:8px}.toolbar{display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:14px}.toolbar.end{justify-content:flex-end;margin-top:14px;margin-bottom:0}.green{border-color:rgba(74,222,128,.45);background:rgba(74,222,128,.15)}.blue{border-color:rgba(96,165,250,.45);background:rgba(96,165,250,.15)}.purple{border-color:rgba(192,132,252,.45);background:rgba(192,132,252,.15)}.red{border-color:rgba(248,113,113,.45);background:rgba(248,113,113,.15)}input,select{border:1px solid var(--line);background:rgba(0,0,0,.24);color:var(--text);border-radius:10px;padding:10px 12px}textarea{width:100%;height:390px;resize:vertical;border-radius:14px;border:1px solid var(--line);background:rgba(0,0,0,.38);color:var(--green);padding:15px;line-height:1.55;font-family:ui-monospace,SFMono-Regular,Consolas,monospace;white-space:pre;overflow:auto;outline:none}.nav-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px}.sub-nav{padding:12px;border-radius:14px;border-left:4px solid var(--blue);background:rgba(0,0,0,.18)}.node-btn{border:1px solid var(--line);background:rgba(255,255,255,.07);color:var(--text);border-radius:10px;padding:10px 16px;cursor:pointer}.node-btn.active{border-color:rgba(74,222,128,.6);color:var(--green);background:rgba(74,222,128,.12)}.region-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(78px,1fr));gap:8px;max-height:360px;overflow:auto}.region-btn{min-height:58px;padding:8px 4px;border:1px solid var(--line);border-radius:12px;background:rgba(15,23,42,.85);color:#cbd5e1;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center}.region-btn.active{border-color:var(--green);background:rgba(74,222,128,.14);color:#fff}.code{font-weight:900}.name{font-size:11px;color:var(--muted)}.table-wrap{overflow:auto;border-radius:14px}.health-table{width:100%;border-collapse:collapse;background:rgba(0,0,0,.18)}.health-table th,.health-table td{padding:10px;border-bottom:1px solid rgba(255,255,255,.08);font-size:13px;text-align:left}.health-table th{background:rgba(255,255,255,.06);color:#cbd5e1}.url-cell{max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--muted)}.status-dot{display:inline-block;width:9px;height:9px;border-radius:50%;margin-right:6px}.ok-dot{background:var(--green);box-shadow:0 0 10px var(--green)}.bad-dot{background:var(--red);box-shadow:0 0 10px var(--red)}.warn{color:var(--yellow);font-size:13px;margin:8px 0 12px}.bar{height:9px;background:rgba(255,255,255,.1);border-radius:99px;overflow:hidden;margin:10px 0}.bar>div{height:100%;width:0;background:var(--blue);transition:.15s}.pill{display:inline-flex;gap:5px;margin:4px;padding:5px 8px;border-radius:7px;border:1px solid var(--green);background:rgba(74,222,128,.13);font-size:12px}.speed-progress{display:none;margin-top:12px}.group-block{background:rgba(0,0,0,.22);border:1px solid var(--line);border-radius:14px;padding:14px;margin:12px 0}.group-head,.node-line{display:flex;gap:10px;align-items:center}.node-line{margin-top:8px;background:rgba(255,255,255,.05);border-radius:10px;padding:10px}.grow{flex:1}@media(max-width:900px){.app-shell{grid-template-columns:1fr}.sidebar{position:static}.stat-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:640px){.main{padding:12px}.topbar,.section-title,.group-head,.node-line{flex-direction:column;align-items:stretch}.stat-grid{grid-template-columns:1fr}}
.result-tools{display:flex;gap:10px;align-items:center;flex-wrap:wrap}.row-failed{background:rgba(248,113,113,.10)}.row-slow{background:rgba(250,204,21,.10)}.row-failed td:first-child{color:#fecaca}.row-slow td:first-child{color:#fde68a}@media(max-width:900px){.sidebar{padding:14px}.brand{margin-bottom:14px}.side-nav{display:flex;overflow-x:auto;padding-bottom:6px}.nav-item{white-space:nowrap;min-width:max-content}.sidebar-foot{display:none}.main{padding:14px}.topbar{position:sticky;top:0;z-index:5}.app-shell{display:block}.toolbar .btn,.toolbar select,.toolbar input,.result-tools .btn{min-height:42px}}@media(max-width:640px){.topbar{align-items:stretch}.top-stats{display:grid;grid-template-columns:repeat(3,1fr)}.top-stats span{text-align:center}.health-table,.health-table thead,.health-table tbody,.health-table th,.health-table td,.health-table tr{display:block}.health-table thead{display:none}.health-table tr{margin:10px 0;border:1px solid var(--line);border-radius:14px;padding:8px;background:rgba(0,0,0,.18)}.health-table td{border-bottom:0;display:flex;justify-content:space-between;gap:12px}.health-table td::before{content:attr(data-label);color:var(--muted);font-weight:700}.url-cell{max-width:100%;white-space:normal;word-break:break-all}.toolbar .btn,.toolbar select,.toolbar label,.toolbar input,.result-tools,.result-tools .btn{width:100%}.result-tools{justify-content:stretch}.region-grid{grid-template-columns:repeat(4,1fr)}textarea{height:52vh}}

.group-summary{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:10px;margin:12px 0}.group-pill{border:1px solid var(--line);background:rgba(0,0,0,.18);border-radius:14px;padding:10px}.group-pill b{display:block;font-size:16px;margin-bottom:4px}.group-pill span{color:var(--muted);font-size:12px}.group-pill.bad{border-color:rgba(248,113,113,.45);background:rgba(248,113,113,.08)}.group-pill.slow{border-color:rgba(250,204,21,.45);background:rgba(250,204,21,.08)}
.artifact-panel{margin:12px 0 14px;padding:14px;border-radius:14px;background:rgba(0,0,0,.20);border:1px solid rgba(255,255,255,.10)}.artifact-head{display:flex;justify-content:space-between;gap:12px;align-items:center;margin-bottom:10px}.artifact-links{display:flex;gap:8px;flex-wrap:wrap}.artifact-links a{padding:7px 10px;border-radius:999px;background:rgba(96,165,250,.12);border:1px solid rgba(96,165,250,.28);color:#bfdbfe;text-decoration:none;font-size:12px}.artifact-links a:hover{background:rgba(96,165,250,.22)}
.artifact-item{display:inline-flex;gap:6px;align-items:center}.artifact-preview-btn{padding:7px 10px;border-radius:999px;border:1px solid rgba(74,222,128,.28);background:rgba(74,222,128,.10);color:#bbf7d0;cursor:pointer;font-size:12px}.artifact-preview-btn:hover{background:rgba(74,222,128,.20)}.artifact-preview{margin-top:12px;border:1px solid var(--line);border-radius:14px;background:rgba(0,0,0,.22);padding:12px}.artifact-preview-head{display:flex;justify-content:space-between;gap:12px;align-items:center;margin-bottom:10px}#artifact-preview-body{max-height:360px;overflow:auto;white-space:pre-wrap;word-break:break-word;margin:0;padding:12px;border-radius:12px;background:rgba(0,0,0,.30);color:#d1fae5;font-size:12px;line-height:1.5}
@media(max-width:640px){.artifact-head,.artifact-preview-head{flex-direction:column;align-items:stretch}.artifact-links{display:grid;grid-template-columns:1fr}.artifact-item{justify-content:space-between}.artifact-item a{flex:1;text-align:center}#artifact-preview-body{max-height:46vh}}
.node-actions{display:inline-flex;gap:6px;align-items:center}.node-actions .node-btn.export{padding-inline:10px;color:#bfdbfe;border-color:rgba(96,165,250,.35);background:rgba(96,165,250,.10)}@media(max-width:640px){.node-actions{width:100%;display:grid;grid-template-columns:1fr auto}.node-actions .node-btn{text-align:center}}

.category-actions{display:flex;justify-content:space-between;gap:10px;align-items:center;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid var(--line)}.category-actions b{font-size:15px}.category-actions .export{color:#bfdbfe;border-color:rgba(96,165,250,.35);background:rgba(96,165,250,.10)}@media(max-width:640px){.category-actions{display:grid;grid-template-columns:1fr auto}}
.import-preview{margin:12px 0 14px;padding:14px;border:1px solid rgba(96,165,250,.35);border-radius:14px;background:rgba(96,165,250,.08)}.import-preview.bad{border-color:rgba(248,113,113,.45);background:rgba(248,113,113,.08)}.import-preview h4{margin:0 0 8px}.import-preview-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:8px;margin:10px 0}.import-preview-stat{padding:9px 10px;border:1px solid var(--line);border-radius:12px;background:rgba(0,0,0,.20)}.import-preview-stat b{display:block;font-size:18px}.import-preview ul{margin:8px 0 0;padding-left:20px}.import-preview-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}@media(max-width:640px){.import-preview-actions .btn{width:100%}}

.save-preview{margin:12px 0 14px;padding:14px;border:1px solid rgba(74,222,128,.35);border-radius:14px;background:rgba(74,222,128,.08)}.save-preview h4{margin:0 0 8px}.save-preview-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:8px;margin:10px 0}.save-preview-stat{padding:9px 10px;border:1px solid var(--line);border-radius:12px;background:rgba(0,0,0,.20)}.save-preview-stat b{display:block;font-size:18px}.save-preview ul{margin:8px 0 0;padding-left:20px}.save-preview-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}@media(max-width:640px){.save-preview-actions .btn{width:100%}}

.archive-panel{margin:12px 0 14px;padding:14px;border:1px solid rgba(96,165,250,.35);border-radius:14px;background:rgba(96,165,250,.08)}.archive-panel h4{margin:0 0 8px}.archive-item{padding:12px;border:1px solid var(--line);border-radius:12px;background:rgba(0,0,0,.18);margin-top:10px}.archive-item-head{display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap}.archive-summary{white-space:pre-wrap;max-height:160px;overflow:auto;margin:8px 0 0;padding:10px;border-radius:10px;background:rgba(0,0,0,.18);font-size:12px}.archive-actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}@media(max-width:640px){.archive-actions .btn{width:100%}}

.archive-filter-summary{margin:8px 0;color:var(--muted);font-size:13px}.archive-empty{padding:12px;border:1px dashed var(--line);border-radius:12px;color:var(--muted)}
